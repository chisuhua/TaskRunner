#!/usr/bin/env bash
# .githooks/pre-commit
# Workstream B.3: Pre-commit hook for TaskRunner
#
# Checks:
#   1. docs-audit.sh — validate H-5 3-scope documentation structure
#   2. clang-format  — check formatting on staged `.cpp` / `.hpp` / `.h` files
#
# Installation:
#   git config core.hooksPath .githooks
#
# Author: TaskRunner owner (Sisyphus H-5.1 session)
# Created: 2026-07-03

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${REPO_ROOT}"

# ── Colors ────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PASS=0
FAIL=0

ok()   { echo -e "${GREEN}✓${NC} $1"; PASS=$((PASS+1)); }
bad()  { echo -e "${RED}✗${NC} $1"; FAIL=$((FAIL+1)); }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }

# ── Check 1: docs-audit.sh ────────────────────────────────────────────────
echo "=== Check 1: Documentation Audit ==="
if [ -x "tools/docs-audit.sh" ]; then
  if bash tools/docs-audit.sh; then
    ok "docs-audit.sh passed"
  else
    bad "docs-audit.sh failed"
  fi
else
  warn "tools/docs-audit.sh not found or not executable — skipping"
fi

# ── Check 2: clang-format on staged files ────────────────────────────────
echo ""
echo "=== Check 2: clang-format ==="

if ! command -v clang-format &>/dev/null; then
  warn "clang-format not found — skipping formatting check"
else
  # Gather staged C++ files
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '\.(cpp|hpp|h)$' || true)

  if [ -z "${STAGED_FILES}" ]; then
    ok "No staged C++ files to check"
  else
    FORMAT_ERRORS=0
    for f in ${STAGED_FILES}; do
      if [ ! -f "$f" ]; then
        continue
      fi
      if ! clang-format --dry-run --Werror "$f" 2>/dev/null; then
        echo -e "  ${RED}✗${NC} $f needs formatting"
        FORMAT_ERRORS=$((FORMAT_ERRORS+1))
      fi
    done

    if [ ${FORMAT_ERRORS} -eq 0 ]; then
      ok "All staged C++ files are properly formatted"
    else
      bad "${FORMAT_ERRORS} file(s) need formatting — run 'clang-format -i' on them"
      # Show diff for the first file
      FIRST_FILE=$(echo "${STAGED_FILES}" | head -1)
      echo ""
      echo "  To fix all, run:"
      echo "    git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(cpp|hpp|h)$' | xargs clang-format -i"
    fi
  fi
fi

# ── Summary ───────────────────────────────────────────────────────────────
echo ""
echo "========================================"
echo "  Summary"
echo "========================================"
echo -e "  ${GREEN}PASS${NC}: ${PASS}"
echo -e "  ${RED}FAIL${NC}: ${FAIL}"
echo ""

if [ ${FAIL} -eq 0 ]; then
  echo -e "  ${GREEN}Pre-commit checks passed${NC}"
  exit 0
else
  echo -e "  ${RED}Pre-commit checks failed${NC}"
  exit 1
fi